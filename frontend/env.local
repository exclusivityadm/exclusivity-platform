# =====================================================
# 🌐 FRONTEND - NEXT.JS CONFIGURATION
# =====================================================

# --- Core URLs ---
NEXT_PUBLIC_APP_NAME=Exclusivity
NEXT_PUBLIC_BACKEND_URL=https://exclusivity-backend.onrender.com
NEXT_PUBLIC_FRONTEND_URL=http://127.0.0.1:3000

# --- Environment Mode ---
NEXT_PUBLIC_ENVIRONMENT=development

# =====================================================
# 🧠 AI Agents (Orion + Lyric)
# =====================================================
NEXT_PUBLIC_AI_AGENT_PRIMARY=orion
NEXT_PUBLIC_AI_AGENT_SECONDARY=lyric
NEXT_PUBLIC_AI_MODEL_GPT=gpt-5
NEXT_PUBLIC_AI_MODEL_TTS=gpt-4o-mini-tts
NEXT_PUBLIC_AI_MODEL_EMBEDDING=text-embedding-3-large
NEXT_PUBLIC_AI_VOICE_ORION=alloy
NEXT_PUBLIC_AI_VOICE_LYRIC=verse

# =====================================================
# 🛍️ Shopify
# =====================================================
NEXT_PUBLIC_SHOPIFY_STORE_URL=
NEXT_PUBLIC_SHOPIFY_API_VERSION=2025-01

# =====================================================
# 🪶 Supabase
# =====================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# =====================================================
# 🔗 Blockchain (Base)
# =====================================================
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_ENABLE_MINTING=true
NEXT_PUBLIC_ENABLE_TOKEN_AESTHETICS=true
NEXT_PUBLIC_COINBASE_DOMAIN_ALLOWLIST=exclusivity.vip
NEXT_PUBLIC_COINBASE_NETWORK=base-mainnet

# =====================================================
# ☁️ Hosting / CI
# =====================================================
NEXT_PUBLIC_VERCEL_PROJECT_NAME=exclusivity-frontend
NEXT_PUBLIC_RENDER_SERVICE_NAME=exclusivity-backend
NEXT_PUBLIC_RENDER_ENVIRONMENT=development
NEXT_PUBLIC_VERCEL_ENVIRONMENT=development


# =====================================================
# 🧩 Integrations
# =====================================================
NEXT_PUBLIC_KLAVIYO_API_KEY=
NEXT_PUBLIC_OMNISEND_API_KEY=
NEXT_PUBLIC_POSTSCRIPT_API_KEY=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# =====================================================
# 🧭 Feature Flags
# =====================================================
NEXT_PUBLIC_FEATURE_POPUP_SHOPS=true
NEXT_PUBLIC_FEATURE_EMPLOYEE_TIERS=true
NEXT_PUBLIC_FEATURE_INVESTOR_TIERS=true
NEXT_PUBLIC_FEATURE_PARTNER_TIERS=true
NEXT_PUBLIC_FEATURE_VENDOR_TIERS=true
NEXT_PUBLIC_FEATURE_VOICE_ENABLED=true
NEXT_PUBLIC_FEATURE_AURA_ENABLED=true

# =====================================================
# 🔐 Security
# =====================================================
NEXT_PUBLIC_CORS_ORIGINS=http://127.0.0.1:3000,https://exclusivity.vercel.app
NEXT_PUBLIC_JWT_ENABLED=true

# =====================================================
# 🧾 Analytics / Logging
# =====================================================
NEXT_PUBLIC_LOG_LEVEL=info
NEXT_PUBLIC_SENTRY_SAMPLE_RATE=0.5
